# ============================================================
# LeadHunter Pro — Umgebungsvariablen
# Kopiere diese Datei als .env und trage deine Werte ein
# ============================================================

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://leads.deinedomain.de

# JWT
JWT_SECRET=HIER_EINEN_LANGEN_ZUFAELLIGEN_STRING_EINTRAGEN_min32zeichen

# Datenbank (MySQL bei deinem Hoster)
DB_HOST=localhost
DB_PORT=3306
DB_USER=dein_db_user
DB_PASSWORD=dein_db_passwort
DB_NAME=leadhunter

# Claude API Key (nur Admin-Funktionalität)
CLAUDE_API_KEY=sk-ant-...

# E-Mail (SMTP — info@novaflowservices.de)
SMTP_HOST=mail.novaflowservices.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@novaflowservices.de
SMTP_PASS=dein_email_passwort
SMTP_FROM="LeadHunter Pro <info@novaflowservices.de>"

# Auto-Logout nach X Minuten Inaktivität
INACTIVITY_TIMEOUT=15

# IMAP — eingehende E-Mails automatisch Leads zuordnen
# Gleicher Server wie SMTP, Port 993 = IMAP mit SSL
IMAP_HOST=mail.novaflowservices.de
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=info@novaflowservices.de
IMAP_PASS=dein_email_passwort
